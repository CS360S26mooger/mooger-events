<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Pink top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:background="#C96B8E"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="16dp">

            <ImageButton
                android:id="@+id/buttonBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_arrow_back"
                android:tint="#FFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Add Availability Slot"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="18sp" />

        </LinearLayout>

        <!-- Scrollable content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none"
            android:clipChildren="false"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- Calendar card — mirrors student booking screen -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="2dp"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <com.example.moogerscouncil.CustomCalendarView
                        android:id="@+id/calendarView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#FFFFFF" />

                </androidx.cardview.widget.CardView>

                <!-- Selected slot info card (hidden until date + time chosen) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSelectedInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="2dp"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFF0F5">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/textSelectedDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableStart="@drawable/ic_nav_calendar"
                            android:drawableTint="#C96B8E"
                            android:drawablePadding="6dp"
                            android:gravity="center_vertical"
                            android:text="—"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#C96B8E" />

                        <TextView
                            android:id="@+id/textSelectedTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableStart="@drawable/ic_nav_history"
                            android:drawableTint="#8B6BAE"
                            android:drawablePadding="6dp"
                            android:gravity="center_vertical"
                            android:text="Tap date to pick time"
                            android:textSize="13sp"
                            android:textColor="#8B6BAE"
                            android:layout_marginTop="6dp"
                            android:visibility="gone" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Create Slot button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonCreateSlot"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Create Slot"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#C96B8E"
                    android:visibility="gone"
                    app:cornerRadius="14dp" />

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

    <!-- Loading overlay -->
    <FrameLayout
        android:id="@+id/progressOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#55000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:background="@drawable/dialog_rounded_bg"
            android:padding="28dp"
            android:gravity="center"
            android:elevation="8dp">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminateTint="#C96B8E"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Creating slot…"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
