<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F4F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="#C96B8E"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/buttonBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="@string/button_cancel" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/availability_settings_title"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/buffer_time_title"
                        android:textColor="#1A1A2E"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/radioBufferGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">

                        <RadioButton
                            android:id="@+id/radioBuffer0"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/buffer_0" />

                        <RadioButton
                            android:id="@+id/radioBuffer10"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/buffer_10" />

                        <RadioButton
                            android:id="@+id/radioBuffer15"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/buffer_15" />

                        <RadioButton
                            android:id="@+id/radioBuffer30"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/buffer_30" />
                    </RadioGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/calendar_export_title"
                        android:textColor="#1A1A2E"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchCalendarExport"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/enable_calendar_export"
                        android:layout_marginTop="8dp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchIcsExport"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/enable_ics_export" />

                    <RadioGroup
                        android:id="@+id/radioCalendarProviderGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">

                        <RadioButton
                            android:id="@+id/radioProviderNone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/provider_none" />

                        <RadioButton
                            android:id="@+id/radioProviderDevice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/provider_device" />

                        <RadioButton
                            android:id="@+id/radioProviderGoogle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/provider_google" />

                        <RadioButton
                            android:id="@+id/radioProviderOutlook"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/provider_outlook" />
                    </RadioGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonSaveAvailabilitySettings"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:text="@string/button_save_settings"
        android:textAllCaps="false"
        android:backgroundTint="#C96B8E"
        app:cornerRadius="12dp" />
</LinearLayout>
