<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F4F8">

    <!-- Pink top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:background="#C96B8E"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/buttonBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_arrow_back"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_manage_availability"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="18sp" />

    </LinearLayout>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonAddSlot"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="@string/button_add_slot"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:backgroundTint="#C96B8E"
            android:stateListAnimator="@null"
            android:elevation="4dp"
            app:icon="@drawable/ic_nav_calendar"
            app:iconTint="#FFFFFF"
            app:iconSize="16dp"
            app:iconGravity="textStart"
            app:cornerRadius="14dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonAvailabilitySettings"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="@string/availability_settings_title"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:textColor="#C96B8E"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:strokeColor="#C96B8E"
            app:strokeWidth="1.5dp"
            app:cornerRadius="14dp" />

    </LinearLayout>

    <!-- Generate Slots button — full-width, below the two top buttons -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonGenerateSlots"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="10dp"
        android:text="Generate Slots"
        android:textSize="13sp"
        android:textColor="#FFFFFF"
        android:textAllCaps="false"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:backgroundTint="#C96B8E"
        android:stateListAnimator="@null"
        android:elevation="4dp"
        app:icon="@drawable/ic_add_cross"
        app:iconTint="#FFFFFF"
        app:iconSize="16dp"
        app:iconGravity="textStart"
        app:cornerRadius="14dp" />

    <!-- Section label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="YOUR SCHEDULE"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#C96B8E"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:paddingHorizontal="20dp"
        android:paddingBottom="4dp" />

    <!-- Slots list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerSlots"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/textEmptySlots"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/no_slots_added"
        android:textSize="14sp"
        android:textColor="#8A8A9A"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone" />

</LinearLayout>
