<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F4F8">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="2dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_manage_availability"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E" />

    </LinearLayout>

    <!-- Add New Slot button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonAddSlot"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:text="@string/button_add_slot"
        app:strokeColor="#3D5AF1"
        app:cornerRadius="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonAvailabilitySettings"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:text="@string/availability_settings_title"
        app:strokeColor="#C96B8E"
        app:cornerRadius="8dp" />

    <!-- Section header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_your_slots"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp" />

    <!-- Slots list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerSlots"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/textEmptySlots"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/no_slots_added"
        android:textSize="14sp"
        android:textColor="#8A8A9A"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone" />

</LinearLayout>
