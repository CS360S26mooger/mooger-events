<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F4F8"
    tools:context=".BookingActivity">

    <!-- Title bar -->
    <TextView
        android:id="@+id/counselorNameTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Book Appointment"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="2dp" />

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:visibility="gone" />

    <!-- Calendar -->
    <CalendarView
        android:id="@+id/calendarView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF" />

    <!-- "Available Times" section header — hidden until a date is tapped -->
    <TextView
        android:id="@+id/labelSlots"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_available_times"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:visibility="gone" />

    <!-- Slot list (horizontal) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/slotsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:clipToPadding="false"
        android:visibility="gone" />

    <!-- Empty state for tapped date with no slots -->
    <TextView
        android:id="@+id/textNoSlots"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/no_slots_for_date"
        android:textSize="14sp"
        android:textColor="#8A8A9A"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone" />

</LinearLayout>
