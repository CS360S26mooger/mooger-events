<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F8">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Avatar placeholder -->
        <ImageView
            android:id="@+id/imageAvatar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@mipmap/ic_launcher_round"
            android:layout_marginBottom="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Counselor name -->
        <TextView
            android:id="@+id/textCounselorName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            app:layout_constraintTop_toBottomOf="@id/imageAvatar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Specialization chips (read-only) -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupSpecializations"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:layout_constraintTop_toBottomOf="@id/textCounselorName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Language -->
        <TextView
            android:id="@+id/textLanguage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Language: —"
            android:textSize="14sp"
            android:textColor="#5A5A7A"
            android:layout_marginBottom="4dp"
            app:layout_constraintTop_toBottomOf="@id/chipGroupSpecializations"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Gender -->
        <TextView
            android:id="@+id/textGender"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Gender: —"
            android:textSize="14sp"
            android:textColor="#5A5A7A"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toBottomOf="@id/textLanguage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Bio card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardBio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/textGender"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_bio"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#8A8A9A"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/textBio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="14sp"
                    android:textColor="#1A1A2E"
                    android:lineSpacingExtra="6dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- On-leave card (shown only when onLeave == true) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardOnLeave"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFF3CD"
            app:layout_constraintTop_toBottomOf="@id/cardBio"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/textOnLeaveTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/on_leave_title"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#856404"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/textOnLeaveMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#856404" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonSeeReferral"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/button_see_referred_counselor"
                    android:visibility="gone"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Book Appointment button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonBookAppointment"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="@string/button_book_appointment"
            android:textSize="16sp"
            android:backgroundTint="#3D5AF1"
            app:cornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/cardOnLeave"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
