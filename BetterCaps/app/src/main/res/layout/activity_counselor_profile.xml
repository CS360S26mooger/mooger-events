<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F4F8">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:background="#C96B8E"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/buttonBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Counselor Profile"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:clipChildren="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Avatar -->
            <ImageView
                android:id="@+id/imageAvatar"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_gravity="center_horizontal"
                android:src="@drawable/ic_student"
                android:tint="#C96B8E"
                android:background="@drawable/circle_bg"
                android:padding="18dp"
                android:layout_marginBottom="16dp" />

            <!-- Counselor name -->
            <TextView
                android:id="@+id/textCounselorName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <!-- Specialization chips (read-only) -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupSpecializations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginBottom="12dp"
                app:chipSpacingHorizontal="6dp" />

            <!-- Language -->
            <TextView
                android:id="@+id/textLanguage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Language: —"
                android:textSize="14sp"
                android:textColor="#5A5A7A"
                android:layout_marginBottom="4dp" />

            <!-- Gender -->
            <TextView
                android:id="@+id/textGender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Gender: —"
                android:textSize="14sp"
                android:textColor="#5A5A7A"
                android:layout_marginBottom="16dp" />

            <!-- Bio card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardBio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="2dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_bio"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#C96B8E"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/textBio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E"
                        android:lineSpacingExtra="4dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- On-leave card (shown only when onLeave == true) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardOnLeave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFF3CD">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/textOnLeaveTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/on_leave_title"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#856404"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/textOnLeaveMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#856404" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonSeeReferral"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/button_see_referred_counselor"
                        android:visibility="gone"
                        android:layout_marginTop="8dp"
                        app:strokeColor="#856404" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Book Appointment button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonBookAppointment"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/button_book_appointment"
                android:textSize="16sp"
                android:backgroundTint="#C96B8E"
                app:cornerRadius="14dp"
                android:layout_marginTop="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonJoinWaitlist"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/join_waitlist"
                android:textSize="16sp"
                android:textColor="#C96B8E"
                android:layout_marginTop="10dp"
                app:strokeColor="#C96B8E"
                app:cornerRadius="14dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
