<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="28dp"
        android:paddingBottom="24dp"
        android:paddingHorizontal="10dp">

        <!--
        <androidx.cardview.widget.CardView
            android:layout_width="116dp"
            android:layout_height="116dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:cardUseCompatPadding="true"
            app:cardBackgroundColor="@color/white">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="🧠"
                android:textSize="36sp"
                android:gravity="center" />
        </androidx.cardview.widget.CardView>
        -->

        <!-- App title -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BetterCAPS"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="℠"
                android:textSize="10sp"
                android:textColor="@color/text_dark"
                android:layout_gravity="bottom" />
        </LinearLayout>

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LUMS Counselling &amp; Psychological Services"
            android:textSize="13sp"
            android:textColor="@color/text_gray"
            android:layout_marginTop="4dp"
            android:gravity="center" />

        <!-- White card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardUseCompatPadding="true"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- I am a... -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="I am a..."
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="12dp" />

                <!-- Role selector row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:layout_marginBottom="20dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStudent"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="Student"
                        android:textSize="11sp"
                        android:maxLines="1"
                        android:paddingTop="14dp"
                        android:paddingBottom="8dp"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:textColor="@color/text_gray"
                        android:backgroundTint="@color/white"
                        app:strokeColor="@color/card_stroke"
                        app:cornerRadius="16dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        app:icon="@drawable/ic_student"
                        app:iconGravity="top"
                        app:iconSize="22dp"
                        app:iconPadding="6dp"
                        app:iconTint="@color/text_gray"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCounselor"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="3dp"
                        android:text="Counselor"
                        android:textSize="11sp"
                        android:maxLines="1"
                        android:paddingTop="14dp"
                        android:paddingBottom="8dp"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:textColor="@color/text_gray"
                        android:backgroundTint="@color/white"
                        app:strokeColor="@color/card_stroke"
                        app:cornerRadius="16dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        app:icon="@drawable/ic_counselor"
                        app:iconGravity="top"
                        app:iconSize="22dp"
                        app:iconPadding="6dp"
                        app:iconTint="@color/text_gray"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAdmin"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="Admin"
                        android:textSize="11sp"
                        android:maxLines="1"
                        android:paddingTop="14dp"
                        android:paddingBottom="8dp"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:textColor="@color/text_gray"
                        android:backgroundTint="@color/white"
                        app:strokeColor="@color/card_stroke"
                        app:cornerRadius="16dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        app:icon="@drawable/ic_admin"
                        app:iconGravity="top"
                        app:iconSize="22dp"
                        app:iconPadding="6dp"
                        app:iconTint="@color/text_gray"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                </LinearLayout>

                <!-- Email label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="6dp" />

                <!-- Email field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:boxStrokeColor="@color/login_field_stroke"
                    app:boxStrokeWidth="1.5dp"
                    app:boxStrokeWidthFocused="1.5dp"
                    app:boxBackgroundColor="#08D4688A"
                    app:hintTextColor="@color/register_pink"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/emailField"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="your.email@university.edu"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/text_dark"
                        android:textColorHint="@color/hint_text"
                        android:textSize="15sp"
                        android:importantForAutofill="no"
                        android:autofillHints="" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="6dp" />

                <!-- Password field with eye toggle -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:passwordToggleEnabled="true"
                    app:boxStrokeColor="@color/login_field_stroke"
                    app:boxStrokeWidth="1.5dp"
                    app:boxStrokeWidthFocused="1.5dp"
                    app:boxBackgroundColor="#08D4688A"
                    app:hintTextColor="@color/register_pink"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/passwordField"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="@color/text_dark"
                        android:textColorHint="@color/hint_text"
                        android:textSize="15sp"
                        android:importantForAutofill="no"
                        android:autofillHints="" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Login button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/loginButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="20dp"
                    android:text="Log In as Student"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary_blue"
                    app:cornerRadius="12dp" />

                <!-- OR divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginVertical="16dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/card_stroke" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  or  "
                        android:textColor="@color/text_gray"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/card_stroke" />

                </LinearLayout>

                <!-- SSO Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/ssoButton"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Continue with University SSO"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    android:textColor="@color/text_dark"
                    android:backgroundTint="@color/white"
                    app:strokeColor="@color/card_stroke"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sign up link -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Don't have an account? "
                android:textColor="@color/text_gray"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/registerLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign Up"
                android:textColor="@color/primary_blue"
                android:textStyle="bold"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Privacy note -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒 Your privacy matters.\nAll sessions are confidential and secure."
            android:textColor="@color/text_gray"
            android:textSize="12sp"
            android:gravity="center"
            android:alpha="0.7"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>
