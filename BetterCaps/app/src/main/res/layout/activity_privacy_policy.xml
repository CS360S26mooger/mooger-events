<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Toolbar -->
    <TextView
        android:id="@+id/privacyTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/title_privacy_policy"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable policy text -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollPolicy"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/privacyTitle"
        app:layout_constraintBottom_toTopOf="@id/buttonAgree"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/privacy_policy_text"
            android:textSize="14sp"
            android:textColor="@color/text_dark"
            android:lineSpacingExtra="6dp"
            android:paddingBottom="16dp" />

    </androidx.core.widget.NestedScrollView>

    <!-- Agree button pinned to bottom -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonAgree"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/button_agree"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:backgroundTint="@color/primary_blue"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="24dp"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
