<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F8F9FA">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_revert"
        android:contentDescription="Back"
        android:layout_marginBottom="32dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Find Your Match"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Answer a few questions to help us match you with the right counselor."
        android:textSize="14sp"
        android:textColor="#8A8A9A"
        android:layout_marginBottom="40dp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Question 1 of 1"
                android:textSize="12sp"
                android:textColor="#3D5AF1"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="What type of problem is bothering you today?"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="32dp" />

            <!-- Options -->
            <Button
                android:id="@+id/btnMentalHealth"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Mental Health &amp; Well-being"
                android:textAllCaps="false"
                android:background="@drawable/edittext_bg"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="12dp"
                android:gravity="start|center_vertical"
                android:paddingStart="20dp"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/btnCareer"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Career &amp; Future Planning"
                android:textAllCaps="false"
                android:background="@drawable/edittext_bg"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="12dp"
                android:gravity="start|center_vertical"
                android:paddingStart="20dp"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/btnAcademics"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Academic Performance"
                android:textAllCaps="false"
                android:background="@drawable/edittext_bg"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="12dp"
                android:gravity="start|center_vertical"
                android:paddingStart="20dp"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/btnRelationships"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Relationships &amp; Family"
                android:textAllCaps="false"
                android:background="@drawable/edittext_bg"
                android:textColor="#1A1A2E"
                android:gravity="start|center_vertical"
                android:paddingStart="20dp"
                app:backgroundTint="@null" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>