<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F4F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#C96B8E"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/buttonBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="@string/button_cancel" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/student_profile_title"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="18sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/textStudentProfileName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/unknown_student"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E" />

                    <TextView
                        android:id="@+id/textStudentPreferredName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_preferred_name_placeholder"
                        android:textSize="14sp"
                        android:textColor="#5A5A7A"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:id="@+id/textStudentPronouns"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_pronouns_placeholder"
                        android:textSize="14sp"
                        android:textColor="#5A5A7A"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/latest_intake_title"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/textIntakeEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/no_intake_found"
                        android:textColor="#8A8A9A"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/textIntakePrimaryConcern"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/intake_primary_concern_placeholder"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E" />

                    <TextView
                        android:id="@+id/textIntakeDuration"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/intake_duration_placeholder"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E"
                        android:layout_marginTop="6dp" />

                    <TextView
                        android:id="@+id/textIntakeSupportType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/intake_support_type_placeholder"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E"
                        android:layout_marginTop="6dp" />

                    <TextView
                        android:id="@+id/textIntakeUrgency"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/intake_urgency_placeholder"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E"
                        android:layout_marginTop="6dp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipIntakeTags"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:chipSpacingHorizontal="6dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/session_notes_title"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/textNotesEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/no_notes_for_student"
                        android:textSize="14sp"
                        android:textColor="#8A8A9A"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerSessionNotes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonViewHistory"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="@string/view_session_history"
                android:textAllCaps="false"
                android:backgroundTint="#8B6BAE"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonAddSessionNote"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="@string/add_session_note"
                android:textAllCaps="false"
                android:layout_marginTop="10dp"
                android:backgroundTint="#C96B8E"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonTriggerCrisis"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="@string/trigger_crisis_escalation"
                android:textAllCaps="false"
                android:textColor="#C0392B"
                android:layout_marginTop="10dp"
                app:strokeColor="#C0392B"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
