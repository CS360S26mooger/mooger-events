<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_rounded_bg"
    android:padding="24dp">

    <!-- Icon -->
    <ImageView
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/ic_nav_calendar"
        android:tint="#8B6BAE"
        android:background="@drawable/circle_bg"
        android:backgroundTint="#EDE8F8"
        android:padding="13dp"
        android:layout_marginBottom="14dp"
        android:contentDescription="Create slot" />

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Create Slot"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:gravity="center"
        android:layout_marginBottom="4dp" />

    <!-- Student name subtitle -->
    <TextView
        android:id="@+id/textSlotStudentName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="#8A8A9A"
        android:gravity="center"
        android:layout_marginBottom="22dp" />

    <!-- Date label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Date"
        android:textColor="#555566"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginBottom="6dp" />

    <!-- Date selector -->
    <LinearLayout
        android:id="@+id/selectorSlotDate"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_time_selector"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="10dp"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/textSlotDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#1A1A2E"
            android:textSize="15sp" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_chevron_down"
            android:contentDescription="Select date" />

    </LinearLayout>

    <!-- Time label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Time"
        android:textColor="#555566"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginBottom="6dp" />

    <!-- Time selector -->
    <LinearLayout
        android:id="@+id/selectorSlotTime"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_time_selector"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="10dp"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/textSlotTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#1A1A2E"
            android:textSize="15sp" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_chevron_down"
            android:contentDescription="Select time" />

    </LinearLayout>

    <!-- Create button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCreateSlotConfirm"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Create Slot"
        android:textSize="15sp"
        android:backgroundTint="#8B6BAE"
        android:layout_marginBottom="10dp"
        app:cornerRadius="14dp" />

    <!-- Cancel button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCreateSlotCancel"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Cancel"
        android:textSize="15sp"
        android:textColor="#8B6BAE"
        app:strokeColor="#8B6BAE"
        app:cornerRadius="14dp" />

</LinearLayout>
