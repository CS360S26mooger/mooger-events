<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_rounded_bg"
    android:padding="28dp">

    <!-- Calendar icon in tinted circle -->
    <ImageView
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/ic_nav_calendar"
        android:tint="#C96B8E"
        android:background="@drawable/circle_bg"
        android:padding="14dp"
        android:layout_marginBottom="18dp" />

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_slot_available_title"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <!-- Body: date + time filled in at runtime -->
    <TextView
        android:id="@+id/textSlotDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#8A8A9A"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:layout_marginBottom="28dp" />

    <!-- Book Now -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBookNow"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="@string/dialog_slot_book_now"
        android:textSize="15sp"
        android:backgroundTint="#C96B8E"
        android:layout_marginBottom="10dp"
        app:cornerRadius="14dp" />

    <!-- Join waitlist instead -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnJoinWaitlistInstead"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="@string/dialog_slot_join_waitlist_instead"
        android:textSize="15sp"
        android:textColor="#C96B8E"
        app:strokeColor="#C96B8E"
        app:cornerRadius="14dp" />

</LinearLayout>
