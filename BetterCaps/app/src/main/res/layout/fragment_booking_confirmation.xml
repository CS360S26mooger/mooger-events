<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/confirm_booking_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="16dp" />

    <!-- Counselor row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_counselor"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/textCounselorName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#5A5A7A" />

    </LinearLayout>

    <!-- Date row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_date"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/textDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#5A5A7A" />

    </LinearLayout>

    <!-- Time row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_time"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/textTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#5A5A7A" />

    </LinearLayout>

    <!-- Confirm button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonConfirmBooking"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/button_confirm_booking"
        android:textSize="16sp"
        android:backgroundTint="#3D5AF1"
        app:cornerRadius="12dp" />

    <!-- Cancel text button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonCancelBooking"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/button_cancel"
        android:textColor="#8A8A9A"
        android:layout_marginTop="8dp" />

</LinearLayout>
