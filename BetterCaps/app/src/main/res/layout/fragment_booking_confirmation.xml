<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bottom_sheet_rounded_bg"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="20dp"
        android:background="#D0D0D8"
        android:backgroundTint="#D0D0D8" />

    <!-- Pink avatar icon -->
    <ImageView
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/ic_student"
        android:tint="#C96B8E"
        android:background="@drawable/circle_bg"
        android:padding="13dp"
        android:layout_marginBottom="14dp" />

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/confirm_booking_title"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:gravity="center"
        android:layout_marginBottom="6dp"
        android:paddingHorizontal="24dp" />

    <!-- Subtitle hint -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Review your details before confirming"
        android:textSize="13sp"
        android:textColor="#9A9AAA"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        android:paddingHorizontal="24dp" />

    <!-- Detail card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#F5EEF8">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Counselor row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_student"
                    android:tint="#C96B8E"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_counselor"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#8B6BAE"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/textCounselorName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textColor="#1A1A2E"
                    android:ellipsize="end"
                    android:maxLines="1" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E8DFF0"
                android:layout_marginBottom="14dp" />

            <!-- Date row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_nav_calendar"
                    android:tint="#C96B8E"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_date"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#8B6BAE"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/textDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textColor="#1A1A2E" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E8DFF0"
                android:layout_marginBottom="14dp" />

            <!-- Time row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_nav_history"
                    android:tint="#C96B8E"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_time"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#8B6BAE"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/textTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textColor="#1A1A2E" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Confirm button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonConfirmBooking"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/button_confirm_booking"
        android:textSize="15sp"
        android:backgroundTint="#C96B8E"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="8dp"
        app:cornerRadius="14dp" />

    <!-- Cancel -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonCancelBooking"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/button_cancel"
        android:textColor="#9A9AAA"
        android:textSize="14sp"
        android:layout_marginHorizontal="20dp" />

</LinearLayout>
