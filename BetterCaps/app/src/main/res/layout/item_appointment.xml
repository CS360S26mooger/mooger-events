<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top row: pastel pink avatar + counselor/student name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_student"
                android:tint="#C96B8E"
                android:background="@drawable/circle_bg"
                android:backgroundTint="#F5E6F0"
                android:padding="10dp"
                android:layout_marginEnd="12dp"
                android:contentDescription="Profile" />

            <TextView
                android:id="@+id/studentName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Counselor Name"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E" />

        </LinearLayout>

        <!-- Bottom chin: date · time · status pill -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/sessionDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mon, Apr 26"
                android:textSize="12sp"
                android:textColor="#8A8A9A"
                android:drawableStart="@drawable/ic_nav_calendar"
                android:drawableTint="#AAAAAA"
                android:drawablePadding="4dp"
                android:gravity="center_vertical" />

            <TextView
                android:id="@+id/sessionTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="10:00"
                android:textSize="12sp"
                android:textColor="#8B6BAE"
                android:drawableStart="@drawable/ic_nav_history"
                android:drawableTint="#8B6BAE"
                android:drawablePadding="4dp"
                android:gravity="center_vertical" />

            <TextView
                android:id="@+id/sessionTopic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Upcoming"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#5E35B1"
                android:background="@drawable/bg_tag_pastel"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp" />

        </LinearLayout>

        <!-- Counselor-facing action buttons — hidden for students via StudentAppointmentAdapter -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/profileButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="👤 Profile"
                android:textSize="12sp"
                android:textColor="#555566"
                android:backgroundTint="#F2F4F8"
                app:cornerRadius="8dp" />

            <Button
                android:id="@+id/notesButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="6dp"
                android:text="📄 Notes"
                android:textSize="12sp"
                android:textColor="#555566"
                android:backgroundTint="#F2F4F8"
                app:cornerRadius="8dp" />

            <Button
                android:id="@+id/joinButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Join"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#8B6BAE"
                app:cornerRadius="8dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/noShowButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Mark No-Show"
                android:textSize="11sp"
                android:textColor="#B8860B"
                android:backgroundTint="#FFFBEA"
                app:cornerRadius="8dp" />

            <Button
                android:id="@+id/crisisButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="⚠ Crisis Alert"
                android:textSize="11sp"
                android:textColor="#C0392B"
                android:backgroundTint="#FFF0F0"
                app:cornerRadius="8dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
