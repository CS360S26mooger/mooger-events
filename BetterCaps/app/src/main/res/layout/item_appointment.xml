<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- Pastel pink avatar -->
        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_student"
            android:tint="#C96B8E"
            android:background="@drawable/circle_bg"
            android:backgroundTint="#F5E6F0"
            android:padding="10dp"
            android:layout_marginEnd="12dp"
            android:contentDescription="Profile" />

        <!-- Student info block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Name row with returning badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/studentName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Student Name"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E" />

                <TextView
                    android:id="@+id/returningStudentBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/returning_student_badge"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#8B6BAE"
                    android:background="@drawable/bg_tag_pastel"
                    android:paddingHorizontal="7dp"
                    android:paddingVertical="3dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Date · time · status pill -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/sessionDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mon, Apr 26"
                    android:textSize="12sp"
                    android:textColor="#8A8A9A"
                    android:drawableStart="@drawable/ic_nav_calendar"
                    android:drawableTint="#AAAAAA"
                    android:drawablePadding="3dp"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/sessionTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10:00"
                    android:textSize="12sp"
                    android:textColor="#8B6BAE"
                    android:drawableStart="@drawable/ic_nav_history"
                    android:drawableTint="#8B6BAE"
                    android:drawablePadding="3dp"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/sessionTopic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confirmed"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#5E35B1"
                    android:background="@drawable/bg_tag_pastel"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp" />

            </LinearLayout>
        </LinearLayout>

        <!-- Trailing chevron — hints the card is tappable -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="22sp"
            android:textColor="#CCCCCC"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
