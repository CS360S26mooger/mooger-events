<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Severity colour strip — 4dp wide, full height -->
        <View
            android:id="@+id/viewSeverityStrip"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#D32F2F" />

        <!-- Body -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Severity badge + date -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/textCrisisAlertSeverity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IMMEDIATE"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#D32F2F"
                    android:background="@drawable/bg_tag_pastel"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/textCrisisAlertDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Apr 26, 10:00"
                    android:textSize="11sp"
                    android:textColor="#8A8A9A" />

            </LinearLayout>

            <!-- Counselor -->
            <TextView
                android:id="@+id/textCrisisAlertCounselor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/crisis_alert_counselor_loading"
                android:textSize="13sp"
                android:textColor="#555566"
                android:layout_marginBottom="2dp" />

            <!-- Student -->
            <TextView
                android:id="@+id/textCrisisAlertStudent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/crisis_alert_student_loading"
                android:textSize="13sp"
                android:textColor="#1A1A2E"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <!-- Action taken -->
            <TextView
                android:id="@+id/textCrisisAlertAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#8A8A9A"
                android:layout_marginBottom="4dp" />

            <!-- Notes (2-line ellipsis) -->
            <TextView
                android:id="@+id/textCrisisAlertNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#555566"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="10dp" />

            <!-- Mark Resolved button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMarkResolved"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/mark_resolved"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:textColor="#D32F2F"
                app:strokeColor="#F5C0C0"
                app:cornerRadius="10dp"
                android:backgroundTint="#FFEBEE" />

        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
