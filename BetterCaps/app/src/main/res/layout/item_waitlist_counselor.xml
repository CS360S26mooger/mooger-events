<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Student name + queue position -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_student"
                android:tint="#C96B8E"
                android:background="@drawable/circle_bg"
                android:backgroundTint="#F5E6F0"
                android:padding="8dp"
                android:layout_marginEnd="10dp"
                android:contentDescription="Student" />

            <TextView
                android:id="@+id/textStudentName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E" />

            <TextView
                android:id="@+id/textQueuePosition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#8B6BAE"
                android:background="@drawable/bg_tag_pastel"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp" />

        </LinearLayout>

        <!-- Preferred dates -->
        <TextView
            android:id="@+id/textPreferredDates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:textSize="13sp"
            android:textColor="#555566" />

        <!-- Time window -->
        <TextView
            android:id="@+id/textTimeWindow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:textSize="13sp"
            android:textColor="#555566" />

        <!-- Note (hidden when empty) -->
        <TextView
            android:id="@+id/textStudentNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:textSize="13sp"
            android:textColor="#777788"
            android:fontFamily="sans-serif-light"
            android:visibility="gone" />

        <!-- Create slot button -->
        <Button
            android:id="@+id/buttonCreateSlot"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="@string/counselor_waitlist_create_slot"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#8B6BAE"
            app:cornerRadius="10dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
