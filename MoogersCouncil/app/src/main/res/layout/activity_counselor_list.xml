<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F4F8">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Find a Specialist"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="12dp" />

        <!-- Search bar -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍"
                    android:textSize="15sp"
                    android:layout_marginEnd="8dp" />

                <EditText
                    android:id="@+id/searchField"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Search by name or issue..."
                    android:textSize="14sp"
                    android:textColorHint="#AAAAAA"
                    android:background="@null"
                    android:inputType="text" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Filter chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/chipAll"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="All"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#3D5AF1"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="18dp" />

                <Button
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Academic Stress"
                    android:textSize="12sp"
                    android:textColor="#1A1A2E"
                    android:backgroundTint="#FFFFFF"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="18dp" />

                <Button
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Career Anxiety"
                    android:textSize="12sp"
                    android:textColor="#1A1A2E"
                    android:backgroundTint="#FFFFFF"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="18dp" />

                <Button
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="General Therapy"
                    android:textSize="12sp"
                    android:textColor="#1A1A2E"
                    android:backgroundTint="#FFFFFF"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="18dp" />

                <Button
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Relationships"
                    android:textSize="12sp"
                    android:textColor="#1A1A2E"
                    android:backgroundTint="#FFFFFF"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="18dp" />

                <Button
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Mindfulness"
                    android:textSize="12sp"
                    android:textColor="#1A1A2E"
                    android:backgroundTint="#FFFFFF"
                    app:cornerRadius="18dp" />

            </LinearLayout>

        </HorizontalScrollView>

    </LinearLayout>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="32dp"
        android:visibility="gone" />

    <!-- Counselor list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/counselorRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="12dp"
        android:clipToPadding="false" />

</LinearLayout>