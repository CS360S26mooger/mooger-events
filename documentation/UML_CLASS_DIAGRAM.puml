'  FEATURE MODELS — Session & Settings
' ════════════════════════════════════════

package "Session & Settings Models" #FFF9C4 {
  class AvailabilitySettings {
    - counselorId : String
    - bufferMinutes : int
    - externalCalendarEnabled : boolean
    - calendarProvider : String
  }
  class SessionNote {
    - id : String
    - appointmentId : String
    - counselorId : String
    - noteText : String
    - templateKey : String
    - appointmentDate : String
  }
  class ReminderSettings {
    - enabled24Hour : boolean
    - enabled1Hour : boolean
    - message24Hour : String
    - message1Hour : String
    --
    + {static} defaultSettings() : ReminderSettings
  }
  class ReminderRecord {
    - id : String
    - appointmentId : String
    - studentId : String
    - reminderType : String
    - scheduledFor : Timestamp
    - delivered : boolean
  }
}

