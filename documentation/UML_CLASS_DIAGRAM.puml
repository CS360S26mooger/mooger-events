' ════════════════════════════════════════
'  CORE REPOSITORIES
' ════════════════════════════════════════

package "Core Repositories" #E3F2FD {
  class UserRepository {
    + createUser(student, cb)
    + getCurrentUser(cb)
    + getCurrentUserRole(cb)
    + getUserName(uid, cb)
  }
  class CounselorRepository {
    + getAllCounselors(cb)
    + getCounselor(id, cb)
    + updateSpecializations(id, tags, cb)
    + setOnLeaveStatus(id, onLeave, msg, refId, cb)
  }
  class AppointmentRepository {
    + bookAppointment(studentId, counselorId, slot, cb)
    + cancelAppointment(apptId, slotId, cb)
    + updateAppointmentStatus(apptId, status, cb)
    + getAppointmentsForCounselor(id, cb)
    + getAppointmentsForStudent(id, cb)
    + getCompletedAppointmentsNeedingFeedback(id, cb)
  }
  class AvailabilityRepository {
    + getSlotsForCounselor(id, cb)
    + getAvailableSlotsForCounselor(id, cb)
    + addSlot(counselorId, date, time, cb)
    + removeSlot(slotId, cb)
  }
  class FeedbackRepository {
    + submitFeedback(feedback, cb)
    + hasFeedbackForAppointment(apptId, cb)
  }
}

' ════════════════════════════════════════
'  FEATURE REPOSITORIES — Session & Settings
' ════════════════════════════════════════

package "Session & Settings Repositories" #DCEDC8 {
  class AvailabilitySettingsRepository {
    + getSettings(counselorId, cb)
    + saveSettings(settings, cb)
  }
  class ReminderRepository {
    + getSettings(counselorId, cb)
    + saveSettings(settings, cb)
    + getDueRemindersForStudent(studentId, cb)
  }
  class SessionNoteRepository {
    + getNoteForAppointment(appointmentId, cb)
    + saveNote(note, cb)
    + updateNote(noteId, text, cb)
  }
}

' ════════════════════════════════════════
'  FEATURE REPOSITORIES — Crisis, Intake & Messaging
' ════════════════════════════════════════

package "Crisis, Intake & Messaging Repositories" #FFCDD2 {
  class CrisisEscalationRepository {
    + createEscalation(escalation, cb)
    + getUnresolvedEscalations(cb)
    + markResolved(id, cb)
  }
  class IntakeAssessmentRepository {
    + saveAssessment(assessment, cb)
    + getLatestForStudent(studentId, cb)
    + getRecommendationCounts(cb)
  }
  class SecureMessageRepository {
    + listenToThread(counselorId, studentId, cb)
    + sendMessage(message, cb)
    + markThreadRead(threadId, uid, cb)
  }
}

' ════════════════════════════════════════
'  FEATURE REPOSITORIES — Waitlist
' ════════════════════════════════════════

package "Waitlist Repository" #C8E6C9 {
  class WaitlistRepository {
    + joinWaitlist(entry, cb)
    + resolveEntry(entryId, cb)
    + getActiveWaitlistForCounselorOrdered(counselorId, cb)
  }
}

' ════════════════════════════════════════
'  UTILITIES — Matching & Validation
' ════════════════════════════════════════

package "Matching & Validation Utilities" #F3E5F5 {
  class BufferTimeValidator <<utility>> {
    + {static} hasConflict(slots, newSlot, bufferMin) : boolean
    + {static} isWithinBlockedWindow(slot, bufferMin) : boolean
  }
  class IntakeMatcher <<utility>> {
    + {static} tagsForAnswers(answers) : List<String>
    + {static} scoreCounselor(counselor, tags) : int
    + {static} findBestCounselor(counselors, tags) : Counselor
  }
  class WaitlistMatcher <<utility>> {
    + {static} matches(entry, slot) : boolean
    + {static} findFirstMatch(entry, slots) : TimeSlot
  }
  class ReturningStudentHelper <<utility>> {
    + {static} markReturningStudents(appointments, cb)
    + {static} isReturningStudent(appointments) : boolean
  }
}

' ════════════════════════════════════════
'  UTILITIES — App & Calendar
' ════════════════════════════════════════

package "App & Calendar Utilities" #EDE7F6 {
  class CalendarSyncHelper <<utility>> {
    + {static} buildInsertEventIntent(appt) : Intent
    + {static} buildIcsLine(appt) : String
  }
  class NoteTemplate <<utility>> {
    + {static} getDisplayName(key) : String
    + {static} getTemplateText(key) : String
  }
  class AppToast <<utility>> {
    + {static} show(context, msg)
    + {static} scheduleForNextActivity(msg)
    + {static} consumePending(context)
  }
  class SessionCache <<singleton>> {
    - {static} instance : SessionCache
    + {static} getInstance() : SessionCache
    + getStudent() : Student
    + putCounselors(list)
    + invalidateAppointments()
  }
  class ReminderScheduler {
    + generateReminderRecords(appointments, settings) : List<ReminderRecord>
  }
}

