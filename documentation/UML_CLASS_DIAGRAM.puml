@startuml BetterCAPS_Class_Diagram

' ── Rendering: top-down, narrow ──
top to bottom direction
skinparam classAttributeIconSize 0
skinparam classFontSize 9
skinparam packageFontSize 11
skinparam nodesep 18
skinparam ranksep 35
skinparam wrapWidth 160
skinparam packageStyle rectangle

title BetterCAPS — Phase 3 Class Diagram (Sprints 1–11)

' ════════════════════════════════════════
'  CONSTANTS
' ════════════════════════════════════════

package "Constants" #E8F5E9 {
  class UserRole <<final>> {
    + {static} STUDENT : String
    + {static} COUNSELOR : String
    + {static} ADMIN : String
  }
  class SpecializationTags <<final>> {
    + {static} ALL_TAGS : String[]
  }
}

' ════════════════════════════════════════
'  CORE MODELS
' ════════════════════════════════════════

package "Core Models" #F5F5DC {
  class Student {
    - uid : String
    - name : String
    - email : String
    - pronouns : String
    - role : String
    - createdAt : Timestamp
  }
  class Counselor {
    - id : String
    - name : String
    - specializations : List<String>
    - isOnLeave : Boolean
    - referralCounselorId : String
  }
  class Appointment {
    - id : String
    - studentId : String
    - counselorId : String
    - date : String
    - time : String
    - status : String
  }
  class TimeSlot {
    - id : String
    - counselorId : String
    - date : String
    - time : String
    - available : boolean
    --
    + book()
  }
  class FeedbackService {
    - id : String
    - appointmentId : String
    - rating : int
    - comment : String
  }
  class AvailabilitySchedule {
    - counselorId : String
    - slotsByDate : Map<String,List<TimeSlot>>
    --
    + {static} fromSlots() : AvailabilitySchedule
    + getSlotsForDate(date) : List<TimeSlot>
    + getDatesWithAvailability() : Set<String>
  }
}

